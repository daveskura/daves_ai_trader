<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dave's AI Trader — Leaderboard</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');

  :root {
    --bg:        #0d0f12;
    --surface:   #141618;
    --surface2:  #1c1f23;
    --border:    #252830;
    --text:      #e2e4e8;
    --muted:     #5a5f6e;
    --accent:    #4af0a0;
    --accent2:   #4ab8f0;
    --red:       #f04a4a;
    --amber:     #f0b84a;
    --mono:      'IBM Plex Mono', monospace;
    --sans:      'IBM Plex Sans', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    font-size: 13px;
    min-height: 100vh;
  }

  /* ── header ── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 28px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    flex-wrap: wrap;
    gap: 12px;
  }
  .logo {
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.3px;
    color: var(--accent);
  }
  .logo span { color: var(--muted); font-weight: 400; }
  .header-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .status-pill {
    font-family: var(--mono);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 100px;
    border: 1px solid var(--border);
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .status-pill .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--muted);
    flex-shrink: 0;
  }
  .status-pill.live .dot {
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    animation: pulse 2s infinite;
  }
  .status-pill.error .dot { background: var(--red); }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }
  .refresh-btn {
    font-family: var(--mono);
    font-size: 11px;
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .refresh-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* ── main layout ── */
  main { padding: 24px 28px 60px; max-width: 1400px; }

  /* ── loading / error states ── */
  .state-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    gap: 12px;
    color: var(--muted);
    font-family: var(--mono);
    font-size: 13px;
    text-align: center;
  }
  .state-box .big { font-size: 28px; }
  .state-box .hint { font-size: 11px; opacity: 0.6; max-width: 400px; line-height: 1.6; }
  #loading-spinner {
    width: 32px; height: 32px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── metrics strip ── */
  .metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 10px;
    margin-bottom: 20px;
  }
  .metric {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }
  .metric .label {
    font-size: 10px;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .metric .value {
    font-family: var(--mono);
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
  }
  .metric .value.pos { color: var(--accent); }
  .metric .value.neg { color: var(--red); }
  .metric .sub {
    font-size: 10px;
    color: var(--muted);
    margin-top: 3px;
    font-family: var(--mono);
  }

  /* ── bar chart ── */
  .section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 16px;
    overflow: hidden;
  }
  .section-head {
    padding: 14px 20px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .section-head .last-update { font-size: 10px; color: var(--muted); opacity: 0.6; }

  .bar-chart { padding: 12px 20px 16px; display: flex; flex-direction: column; gap: 7px; }
  .bar-row { display: flex; align-items: center; gap: 10px; }
  .bar-id { width: 26px; font-family: var(--mono); font-size: 10px; color: var(--muted); flex-shrink: 0; }
  .bar-name { width: 210px; font-size: 12px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex-shrink: 0; }
  .bar-track { flex: 1; background: var(--surface2); border-radius: 3px; height: 18px; position: relative; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s cubic-bezier(.4,0,.2,1); min-width: 2px; }
  .bar-fill.pos { background: linear-gradient(90deg, #1d9e75, #4af0a0); }
  .bar-fill.neg { background: linear-gradient(90deg, #a33030, #f04a4a); }
  .bar-fill.passive { opacity: 0.45; }
  .bar-pct { width: 64px; font-family: var(--mono); font-size: 11px; font-weight: 600; text-align: right; flex-shrink: 0; }
  .bar-pct.pos { color: var(--accent); }
  .bar-pct.neg { color: var(--red); }

  /* ── table ── */
  .table-scroll { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--muted);
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    position: sticky;
    top: 0;
    background: var(--surface);
  }
  thead th.num { text-align: right; }
  tbody td { padding: 9px 14px; border-bottom: 1px solid var(--border); }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--surface2); }
  td.num { text-align: right; font-family: var(--mono); font-size: 12px; }
  td.mono { font-family: var(--mono); font-size: 12px; }

  /* rank medals */
  .rank-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    border-radius: 50%;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
  }
  .rank-1 { background: rgba(240,184,74,.15); color: var(--amber); border: 1px solid rgba(240,184,74,.3); }
  .rank-2 { background: rgba(180,180,180,.12); color: #aaa; border: 1px solid rgba(180,180,180,.25); }
  .rank-3 { background: rgba(200,130,80,.12); color: #c87850; border: 1px solid rgba(200,130,80,.25); }
  .rank-n  { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

  /* badges */
  .badge {
    display: inline-block;
    font-size: 10px;
    font-family: var(--mono);
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .style-momentum   { background: rgba(74,184,240,.1); color: var(--accent2); border: 1px solid rgba(74,184,240,.2); }
  .style-contrarian { background: rgba(74,240,160,.1); color: var(--accent);  border: 1px solid rgba(74,240,160,.2); }
  .style-value      { background: rgba(74,240,160,.1); color: var(--accent);  border: 1px solid rgba(74,240,160,.2); }
  .style-growth     { background: rgba(74,184,240,.1); color: var(--accent2); border: 1px solid rgba(74,184,240,.2); }
  .style-macro      { background: rgba(180,130,240,.1);color: #c084fc;        border: 1px solid rgba(180,130,240,.2); }
  .style-defensive  { background: rgba(74,240,160,.1); color: #7af4c0;        border: 1px solid rgba(74,240,160,.2); }
  .style-event      { background: rgba(240,184,74,.1); color: var(--amber);   border: 1px solid rgba(240,184,74,.2); }
  .style-income     { background: rgba(74,240,160,.1); color: #7af4c0;        border: 1px solid rgba(74,240,160,.2); }
  .style-altdata    { background: rgba(240,184,74,.1); color: var(--amber);   border: 1px solid rgba(240,184,74,.2); }
  .style-academic   { background: rgba(240,120,120,.1);color: #f08080;        border: 1px solid rgba(240,120,120,.2); }
  .style-passive    { background: rgba(90,95,110,.15); color: var(--muted);   border: 1px solid var(--border); }
  .style-speculative{ background: rgba(240,74,74,.1); color: var(--red);      border: 1px solid rgba(240,74,74,.2); }
  .style-thematic   { background: rgba(180,130,240,.1);color: #c084fc;        border: 1px solid rgba(180,130,240,.2); }

  .risk-high { background: rgba(240,74,74,.1);  color: var(--red);   border: 1px solid rgba(240,74,74,.2); }
  .risk-med  { background: rgba(240,184,74,.1); color: var(--amber); border: 1px solid rgba(240,184,74,.2); }
  .risk-low  { background: rgba(74,240,160,.1); color: var(--accent);border: 1px solid rgba(74,240,160,.2); }

  .pos-val { color: var(--accent); font-weight: 600; }
  .neg-val { color: var(--red);    font-weight: 600; }
  .passive-row td { opacity: 0.55; }

  /* manual upload fallback */
  .upload-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0 0;
    font-size: 11px;
    color: var(--muted);
    font-family: var(--mono);
  }
  .upload-row label {
    cursor: pointer;
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: all 0.15s;
  }
  .upload-row label:hover { border-color: var(--accent2); color: var(--accent2); }
  .upload-row input { display: none; }

  @media (max-width: 700px) {
    header, main { padding-left: 16px; padding-right: 16px; }
    .bar-name { width: 120px; }
    thead th:nth-child(n+7), tbody td:nth-child(n+7) { display: none; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">dave's_ai_trader<span>/leaderboard</span></div>
  <div class="header-right">
    <div class="status-pill" id="status-pill">
      <div class="dot"></div>
      <span id="status-text">loading…</span>
    </div>
    <button class="refresh-btn" onclick="loadCSV()">↺ refresh</button>
  </div>
</header>

<main id="main">
  <div class="state-box" id="loading-state">
    <div id="loading-spinner"></div>
    <div>Loading leaderboard.csv…</div>
  </div>

  <div class="state-box" id="error-state" style="display:none">
    <div class="big">⚠</div>
    <div id="error-msg">Could not load leaderboard.csv</div>
    <div class="hint" id="error-hint"></div>
    <div class="upload-row">
      <span>Or load manually:</span>
      <label>Browse CSV <input type="file" id="file-input" accept=".csv"></label>
    </div>
  </div>

  <div id="dashboard" style="display:none">
    <div class="metrics" id="metrics"></div>

    <div class="section">
      <div class="section-head">
        <span>Return by strategy</span>
        <span class="last-update" id="last-update"></span>
      </div>
      <div class="bar-chart" id="bar-chart"></div>
    </div>

    <div class="section">
      <div class="section-head">Strategy breakdown</div>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>ID</th>
              <th>Strategy</th>
              <th>Style</th>
              <th>Risk</th>
              <th class="num">Cash</th>
              <th class="num">Holdings</th>
              <th class="num">Total</th>
              <th class="num">P&amp;L</th>
              <th class="num">Return</th>
              <th class="num">Trades</th>
            </tr>
          </thead>
          <tbody id="table-body"></tbody>
        </table>
      </div>
    </div>

    <div class="upload-row" style="justify-content:flex-end">
      <span>Load different CSV:</span>
      <label>Browse <input type="file" id="file-input2" accept=".csv"></label>
    </div>
  </div>
</main>

<script>
// ── CSV parser ────────────────────────────────────────────────────────────────
function parseCSV(text) {
  const lines = text.trim().split('\n');
  const headers = lines[0].split(',').map(h => h.trim());
  return lines.slice(1)
    .filter(l => l.trim())
    .map(line => {
      const vals = line.split(',');
      const obj = {};
      headers.forEach((h, i) => obj[h] = (vals[i] || '').trim());
      return obj;
    });
}

// ── Formatters ────────────────────────────────────────────────────────────────
const fmt  = n => '$' + Math.abs(parseFloat(n)||0).toLocaleString('en-US', {minimumFractionDigits:2,maximumFractionDigits:2});
const sign = n => (parseFloat(n)||0) >= 0 ? '+' : '-';
const fmtPct = n => { const v = parseFloat(n)||0; return (v>=0?'+':'')+v.toFixed(2)+'%'; };

// ── Render ────────────────────────────────────────────────────────────────────
function render(data) {
  if (!data || !data.length) {
    showError('leaderboard.csv is empty or malformed.');
    return;
  }
  data.sort((a,b) => (parseFloat(b.total)||0) - (parseFloat(a.total)||0));
  data.forEach((d,i) => d._rank = i+1);

  const best   = data[0];
  const worst  = data[data.length-1];
  const totals = data.map(d => parseFloat(d.total)||0);
  const avg    = totals.reduce((a,b)=>a+b,0) / totals.length;
  const winners= data.filter(d => (parseFloat(d.pnl)||0) > 0).length;
  const date   = data[0]?.date || '—';

  // status pill
  const pill = document.getElementById('status-pill');
  pill.className = 'status-pill live';
  document.getElementById('status-text').textContent = 'live · ' + date;

  document.getElementById('last-update').textContent = 'as of ' + date;

  // ── metrics ──
  const pnlBest = parseFloat(best?.pnl||0);
  document.getElementById('metrics').innerHTML = `
    <div class="metric">
      <div class="label">Top strategy</div>
      <div class="value" style="font-size:14px;color:var(--amber)">${best?.strategy_name?.split('(')[0].trim()||'—'}</div>
      <div class="sub">#${best?._rank} of ${data.length}</div>
    </div>
    <div class="metric">
      <div class="label">Best return</div>
      <div class="value ${pnlBest>=0?'pos':'neg'}">${fmtPct(best?.pct_return)}</div>
      <div class="sub">${sign(pnlBest)}${fmt(Math.abs(pnlBest))} P&L</div>
    </div>
    <div class="metric">
      <div class="label">Avg portfolio</div>
      <div class="value">${fmt(avg)}</div>
      <div class="sub">starting $1,000.00</div>
    </div>
    <div class="metric">
      <div class="label">Strategies winning</div>
      <div class="value pos">${winners}</div>
      <div class="sub">of ${data.length} total</div>
    </div>
    <div class="metric">
      <div class="label">Worst return</div>
      <div class="value ${(parseFloat(worst?.pnl||0))>=0?'pos':'neg'}">${fmtPct(worst?.pct_return)}</div>
      <div class="sub">${worst?.strategy_name?.split('/')[0].trim()||'—'}</div>
    </div>
    <div class="metric">
      <div class="label">Total trades</div>
      <div class="value">${data.reduce((s,d)=>s+(parseInt(d.trades)||0),0).toLocaleString()}</div>
      <div class="sub">across all strategies</div>
    </div>
  `;

  // ── bar chart ──
  const maxAbs = Math.max(...data.map(d=>Math.abs(parseFloat(d.pct_return)||0)), 0.1);
  document.getElementById('bar-chart').innerHTML = data.map(d => {
    const pct  = parseFloat(d.pct_return)||0;
    const w    = Math.max(Math.abs(pct)/maxAbs*100, 1);
    const pos  = pct >= 0;
    const isP  = d.style === 'passive';
    return `
      <div class="bar-row">
        <div class="bar-id">${d.strategy_id}</div>
        <div class="bar-name" title="${d.strategy_name}">${d.strategy_name}</div>
        <div class="bar-track">
          <div class="bar-fill ${pos?'pos':'neg'}${isP?' passive':''}" style="width:${w}%"></div>
        </div>
        <div class="bar-pct ${pos?'pos':'neg'}">${fmtPct(pct)}</div>
      </div>`;
  }).join('');

  // ── table ──
  function styleClass(s) {
    const map = {'alt-data':'altdata'};
    return 'style-' + (map[s] || (s||'').replace(/[^a-z]/g,''));
  }
  document.getElementById('table-body').innerHTML = data.map(d => {
    const pnl  = parseFloat(d.pnl)||0;
    const pos  = pnl >= 0;
    const r    = d._rank;
    const isP  = d.style === 'passive';
    const rankHtml =
      r===1 ? `<span class="rank-badge rank-1">1</span>` :
      r===2 ? `<span class="rank-badge rank-2">2</span>` :
      r===3 ? `<span class="rank-badge rank-3">3</span>` :
              `<span class="rank-badge rank-n">${r}</span>`;
    return `
      <tr class="${isP?'passive-row':''}">
        <td>${rankHtml}</td>
        <td class="mono" style="color:var(--muted)">${d.strategy_id}</td>
        <td>${d.strategy_name}</td>
        <td><span class="badge ${styleClass(d.style)}">${d.style}</span></td>
        <td><span class="badge risk-${d.risk||'low'}">${d.risk}</span></td>
        <td class="num">${fmt(d.cash)}</td>
        <td class="num">${fmt(d.holdings_value)}</td>
        <td class="num" style="font-weight:600">${fmt(d.total)}</td>
        <td class="num ${pos?'pos-val':'neg-val'}">${sign(pnl)}${fmt(Math.abs(pnl))}</td>
        <td class="num ${pos?'pos-val':'neg-val'}">${fmtPct(d.pct_return)}</td>
        <td class="num" style="color:var(--muted)">${d.trades}</td>
      </tr>`;
  }).join('');

  document.getElementById('loading-state').style.display = 'none';
  document.getElementById('error-state').style.display   = 'none';
  document.getElementById('dashboard').style.display     = 'block';
}

// ── Error display ─────────────────────────────────────────────────────────────
function showError(msg, hint) {
  document.getElementById('loading-state').style.display = 'none';
  document.getElementById('dashboard').style.display     = 'none';
  document.getElementById('error-state').style.display   = 'flex';
  document.getElementById('error-msg').textContent       = msg;
  document.getElementById('error-hint').textContent      = hint || '';
  const pill = document.getElementById('status-pill');
  pill.className = 'status-pill error';
  document.getElementById('status-text').textContent = 'offline';
}

// ── Load CSV via fetch (same-origin) ─────────────────────────────────────────
function loadCSV() {
  document.getElementById('loading-state').style.display = 'flex';
  document.getElementById('dashboard').style.display     = 'none';
  document.getElementById('error-state').style.display   = 'none';
  document.getElementById('status-pill').className       = 'status-pill';
  document.getElementById('status-text').textContent     = 'loading…';

  // Cache-bust with timestamp so we always get the latest file
  fetch('leaderboard.csv?t=' + Date.now())
    .then(r => {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.text();
    })
    .then(text => render(parseCSV(text)))
    .catch(err => showError(
      'Could not load leaderboard.csv automatically.',
      'Make sure leaderboard.html and leaderboard.csv are in the same Apache-served directory. ' +
      'Error: ' + err.message + '. You can also load the CSV manually using the button below.'
    ));
}

// ── Manual file-picker fallback ───────────────────────────────────────────────
function bindFilePicker(id) {
  document.getElementById(id).addEventListener('change', e => {
    const f = e.target.files[0];
    if (!f) return;
    const reader = new FileReader();
    reader.onload = ev => render(parseCSV(ev.target.result));
    reader.readAsText(f);
  });
}
bindFilePicker('file-input');
bindFilePicker('file-input2');

// ── Auto-refresh every 5 minutes ─────────────────────────────────────────────
const REFRESH_MS = 5 * 60 * 1000;
setInterval(loadCSV, REFRESH_MS);

// ── Initial load ──────────────────────────────────────────────────────────────
loadCSV();
</script>
</body>
</html>
